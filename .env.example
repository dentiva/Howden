# Copy this file to .env for local development and fill in your key.
# On Railway, set these in the service variables instead of using a .env file.

# Required for the Claude advisor chat.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional. Override the Claude model if your account has access to a different one.
# Defaults to claude-sonnet-4-5. Examples: claude-sonnet-4-5, claude-sonnet-4-6, claude-opus-4-7
# CLAUDE_MODEL=claude-sonnet-4-5

# Optional. Railway sets this automatically. Only override for local dev.
PORT=3000
